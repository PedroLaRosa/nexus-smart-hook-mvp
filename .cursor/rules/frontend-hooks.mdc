## Complete Example

```typescript
import { useState } from 'react';
import { Maybe } from '../shared/domain/Maybe';
import { ProfileDTO } from '../../application/ProfileDTO';
import { GetProfileUseCase } from '../../application/GetProfileUseCase';

interface ProfileState {
  profile: Maybe<ProfileDTO>;
  loading: boolean;
  error: Maybe<Error>;
}

const initialState: ProfileState = {
  profile: Maybe.none(),
  loading: false,
  error: Maybe.none(),
};

export function useProfile(useCase: GetProfileUseCase) {
  const [state, setState] = useState<ProfileState>(initialState);

  const startLoading = () => {
    setState(prev => ({ ...prev, loading: true, error: Maybe.none() }));
  };

  const setProfile = (profile: ProfileDTO) => {
    setState(prev => ({ ...prev, profile: Maybe.some(profile), loading: false }));
  };

  const setError = (error: Error) => {
    setState(prev => ({ ...prev, error: Maybe.some(error), loading: false }));
  };

  const loadProfile = async () => {
    startLoading();
    try {
      const profile = await useCase.execute();
      setProfile(profile);
    } catch (error) {
      setError(error as Error);
    }
  };

  return {
    profile: state.profile,
    loading: state.loading,
    error: state.error,
    loadProfile,
  };
}
```

---

## Allowed Hooks

| Hook | Where | Use |
|------|-------|-----|
| `useState` | Custom Hook | One per hook, grouped state |
| `useEffect` | Component | Lifecycle, NOT in hooks |
| `useRef` | Component | DOM references only |

## Prohibited Hooks

- `useContext` / `createContext` - use Subjects
- `useMemo` / `useCallback` - premature optimization
- `useReducer` - useState is enough
- Any hook inside custom hooks (except the single useState)

---

## State with Maybe

- Use `Maybe<T>` for optional values, **never null**
- Initial state uses `Maybe.none()` for optional fields

```typescript
import { Maybe } from '../shared/domain/Maybe';
```

## File Naming

- `ComponentName.hook.ts` (e.g., `Profile.hook.ts`)

## Consuming Hooks

- **Do NOT destructure** hook results
- Use `hook.property` pattern for clarity

```typescript
// Bad - destructuring
const { profile, loading, loadProfile } = useProfile(useCase);

// Good - hook.property
const profileHook = useProfile(useCase);
// usage: profileHook.profile, profileHook.loading, profileHook.loadProfile()
```

---

## Non-Negotiable Rules

### NEVER:
1. Use Context API (useContext, createContext)
2. Put useEffect or other hooks inside custom hooks
3. Declare multiple useState calls
4. Use useReducer
5. Expose state or setState directly
6. Nest functions inside functions
7. Use null/undefined for optional values (use Maybe)
8. Destructure hook results when consuming
9. Call dependencies globally inside hooks
10. Update state without using previous state (`prev => ...`)
11. Call repositories or fetch directly (use UseCases)
12. Import from infrastructure/adapters/

### ALWAYS:
1. Pass dependencies (use cases) as parameters
2. Group state in a single typed interface
3. Use `Maybe.none()` for initial optional values
4. Encapsulate state changes in explicit functions
5. Use `setState(prev => ...)` pattern
6. Keep hooks simple - refactor if they grow
7. Use `hook.property` pattern when consuming hooks
8. Access external services only through UseCases
9. Use domain pure functions for transformations